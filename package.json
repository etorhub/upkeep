{
  "name": "home-maintenance-card",
  "type": "module",
  "version": "1.0.0",
  "description": "A custom Lovelace card for the Home Maintenance integration — visual progress tracking, auto-discovery, and one-tap task completion.",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "lovelace",
    "custom-cards",
    "hacs",
    "maintenance"
  ],
  "module": "home-maintenance-card.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/etorhub/home-maintenance-card"
  },
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "lodash": ">=4.17.22",
    "tmp": ">=0.2.4",
    "tar": ">=7.5.10",
    "minimatch": ">=10.2.3",
    "npm": ">=11.10.0"
  },
  "dependencies": {
    "custom-card-helpers": "^2.0.0",
    "home-assistant-js-websocket": "^9.6.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@open-wc/testing": "^4.0.0",
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.0",
    "@rollup/plugin-typescript": "^11.1.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/addon-viewport": "^8.6.18",
    "@storybook/blocks": "^8.6.14",
    "@storybook/test-runner": "^0.21.3",
    "@storybook/web-components-vite": "^8.6.18",
    "@testing-library/dom": "^10.4.0",
    "commitizen": "^4.3.1",
    "concurrently": "^9.2.1",
    "conventional-changelog-conventionalcommits": "7.0.2",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^15.12.0",
    "http-server": "^14.1.1",
    "jsdom": "^25.0.1",
    "lefthook": "^1.7.0",
    "prettier": "^3.3.3",
    "rollup": "^4.20.0",
    "rollup-plugin-esbuild-minify": "^1.3.0",
    "rollup-plugin-serve": "^1.1.1",
    "semantic-release": "^25.0.3",
    "storybook": "^8.6.18",
    "tslib": "^2.6.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.5"
  },
  "scripts": {
    "commit": "cz",
    "start": "rollup -c rollup.config.dev.js --watch",
    "build": "npm run clean && rollup -c",
    "clean": "rm -rf dist",
    "lint": "eslint src tests .storybook",
    "lint:fix": "eslint src tests .storybook --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\" \".storybook/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\" \".storybook/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "concurrently -k -s first -n \"SB,TEST\" -c \"blue,green\" \"npx http-server storybook-static -p 6006 -c-1\" \"wait-on tcp:127.0.0.1:6006 && npx test-storybook --url http://127.0.0.1:6006\"",
    "test-storybook:ci": "npm run build-storybook && npm run test-storybook"
  }
}